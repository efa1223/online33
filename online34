<script>
// ═══════════════════════════════════════════
// GLOBALS
// ═══════════════════════════════════════════
var API = localStorage.getItem('neo_api') || '';
var products = [];
var cart = safeJSON(localStorage.getItem('neo_cart'), []);
var recent = safeJSON(localStorage.getItem('neo_recent'), []);
var curCat = 'all';
var coupon = null;
var SHIP_MIN = 200000;
var SHIP_COST = 15000;

// ═══════════════════════════════════════════
// BOOT
// ═══════════════════════════════════════════
document.addEventListener('DOMContentLoaded', function() {
  if (API) { document.getElementById('inpApi').value = API; fetchProducts(); fetchOrders(); fetchStats(); }
  else { demoProd(); }
  syncCartUI();
  countdown();
  socialLoop();
  catNavBind();
});

// ═══════════════════════════════════════════
// API HELPERS
// ═══════════════════════════════════════════
function GET(action, extra) {
  if (!API) return Promise.resolve(null);
  return fetch(API + '?action=' + action + (extra || ''))
    .then(function(r) { return r.json(); })
    .catch(function() { return null; });
}

function POST(body) {
  if (!API) return Promise.resolve(null);
  return fetch(API, { method:'POST', headers:{'Content-Type':'text/plain'}, body: JSON.stringify(body) })
    .then(function(r) { return r.json(); })
    .catch(function() { return null; });
}

// ═══════════════════════════════════════════
// PRODUCTS
// ═══════════════════════════════════════════
function fetchProducts() {
  GET('getProducts').then(function(r) {
    if (r && r.success && r.products && r.products.length) { products = r.products; }
    else { demoProd(); }
    renderProducts(); renderFlash(); renderRecent();
  });
}

function demoProd() {
  products = [
    {id:'d1',name:'Headphone Wireless Quantum X',price:450000,category:'elektronik',stock:25,description:'Active Noise Cancellation, battery 40 jam, driver 50mm, Bluetooth 5.3. Bass powerful untuk pecinta musik.',image:'https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=400&q=80',discount:20,sold:342,rating:4.8,reviews:156},
    {id:'d2',name:'Smart Watch Ultra Series 5',price:1250000,category:'elektronik',stock:8,description:'Layar AMOLED 1.9", SpO2 + ECG, GPS, water resistant 50m. Health monitoring lengkap di pergelangan tangan.',image:'https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400&q=80',discount:15,sold:89,rating:4.9,reviews:67},
    {id:'d3',name:'Jaket Bomber Cyberpunk Edition',price:385000,category:'fashion',stock:50,description:'Limited edition, detail reflektif 3M, zipper YKK premium, inner satin, bahan water-resistant.',image:'https://images.unsplash.com/photo-1551028719-00167b16eac5?w=400&q=80',discount:0,sold:215,rating:4.7,reviews:98},
    {id:'d4',name:'Sneakers Air Neon 2026',price:890000,category:'fashion',stock:3,description:'Sole glow-in-the-dark, breathable mesh, cushion technology. Nyaman seharian.',image:'https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=400&q=80',discount:10,sold:567,rating:4.6,reviews:234},
    {id:'d5',name:'Matcha Ceremonial Grade 500g',price:125000,category:'makanan',stock:100,description:'Grade ceremonial dari Uji, Kyoto. Rasa umami halus, cocok latte dan baking.',image:'https://images.unsplash.com/photo-1556881286-fc6915169721?w=400&q=80',discount:5,sold:1203,rating:4.9,reviews:445},
    {id:'d6',name:'Vitamin C 1000mg + Zinc',price:175000,category:'kesehatan',stock:200,description:'Rose hip dan zinc, 60 kapsul vegetarian, halal certified. Daya tahan tubuh optimal.',image:'https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?w=400&q=80',discount:0,sold:890,rating:4.8,reviews:312},
    {id:'d7',name:'Diffuser Aromaterapi Crystal',price:285000,category:'rumah',stock:40,description:'Ultrasonik 300ml, LED RGB, timer 1/3/6 jam, auto-shutoff. Design crystal premium.',image:'https://images.unsplash.com/photo-1602928321679-560bb453f190?w=400&q=80',discount:25,sold:445,rating:4.7,reviews:178},
    {id:'d8',name:'Keyboard Mechanical RGB',price:650000,category:'elektronik',stock:35,description:'Hot-swappable, Gateron Pro Yellow, RGB per-key, PBT keycaps, wireless tri-mode.',image:'https://images.unsplash.com/photo-1618384887929-16ec33fab9ef?w=400&q=80',discount:30,sold:234,rating:4.9,reviews:156},
    {id:'d9',name:'Tas Ransel Anti-Theft',price:320000,category:'fashion',stock:60,description:'USB charging, hidden zipper, laptop 15.6", waterproof Oxford. Anti-maling.',image:'https://images.unsplash.com/photo-1553062407-98eeb64c6a62?w=400&q=80',discount:15,sold:678,rating:4.6,reviews:289},
    {id:'d10',name:'Madu Hutan Kalimantan 650ml',price:185000,category:'makanan',stock:75,description:'Raw unprocessed, kaya antioksidan, enzim alami. Lab-tested, BPOM certified.',image:'https://images.unsplash.com/photo-1587049352846-4a222e784d38?w=400&q=80',discount:0,sold:445,rating:4.8,reviews:167}
  ];
  renderProducts(); renderFlash(); renderRecent();
}

function renderProducts() {
  var g = document.getElementById('prodGrid');
  var list = products;
  if (curCat !== 'all') list = list.filter(function(p){return p.category===curCat;});
  var q = document.getElementById('inpSearch').value.toLowerCase();
  if (q) list = list.filter(function(p){return p.name.toLowerCase().indexOf(q)!==-1;});

  if (!list.length) { g.innerHTML='<p style="grid-column:1/-1;text-align:center;color:var(--text-muted);padding:40px">Tidak ada produk</p>'; return; }

  var h = '';
  for (var i=0;i<list.length;i++) {
    var p=list[i], fp=p.discount>0?Math.round(p.price*(1-p.discount/100)):p.price;
    var low=p.stock<=5&&p.stock>0, rat=p.rating||(4+Math.random()).toFixed(1), sold=p.sold||0;
    h+='<div class="card" onclick="showPD(\''+p.id+'\')">';
    h+='<div class="pic"><img src="'+(p.image||'https://placehold.co/300x300/1c2230/00d4aa?text=P')+'" alt="" loading="lazy" onerror="this.src=\'https://placehold.co/300x300/1c2230/00d4aa?text=P\'">';
    if(p.discount>0) h+='<span class="tag-disc">-'+p.discount+'%</span>';
    h+='<span class="tag-sold">'+sold+' terjual</span>';
    h+='<button class="btn-wish" onclick="event.stopPropagation();wish(this)">♡</button></div>';
    h+='<div class="body"><div class="title">'+p.name+'</div>';
    h+='<div class="price-row">Rp '+fmt(fp);
    if(p.discount>0) h+='<span class="old">Rp '+fmt(p.price)+'</span>';
    h+='</div><div class="meta-row"><span class="star">★ '+rat+'</span><span>'+(p.stock>0?'Stok '+p.stock:'Habis')+'</span></div>';
    if(low) h+='<div class="low-stock">Sisa '+p.stock+' lagi!</div>';
    h+='</div>';
    h+='<div class="hover-btns"><button class="hb-cart" onclick="event.stopPropagation();addCart(\''+p.id+'\')">+ Keranjang</button><button class="hb-buy" onclick="event.stopPropagation();buyNow(\''+p.id+'\')">Beli</button></div>';
    h+='</div>';
  }
  g.innerHTML=h;
}

function renderFlash() {
  var items=products.filter(function(p){return p.discount>=15;}).slice(0,8);
  if(!items.length){document.getElementById('flashWrap').style.display='none';return;}
  document.getElementById('flashWrap').style.display='';
  var h='';
  for(var i=0;i<items.length;i++){
    var p=items[i],sp=Math.round(p.price*(1-p.discount/100));
    var pct=Math.min(((p.sold||0)/((p.sold||0)+(p.stock||1)))*100,95);
    h+='<div class="fs-card" onclick="showPD(\''+p.id+'\')">';
    h+='<div class="thumb"><img src="'+p.image+'" alt="" loading="lazy" onerror="this.src=\'https://placehold.co/145x145/1c2230/00d4aa?text=P\'"></div>';
    h+='<div class="fs-body"><div class="fs-price">Rp '+fmt(sp)+'</div><div class="fs-old">Rp '+fmt(p.price)+'</div>';
    h+='<div class="fs-bar"><div class="fs-fill" style="width:'+pct+'%"></div></div>';
    h+='<div class="fs-label">Terjual '+Math.round(pct)+'%</div></div></div>';
  }
  document.getElementById('flashGrid').innerHTML=h;
}

// ═══════════════════════════════════════════
// PRODUCT DETAIL
// ═══════════════════════════════════════════
function showPD(id) {
  var p=find(id); if(!p) return;
  addRecent(id);
  var fp=p.discount>0?Math.round(p.price*(1-p.discount/100)):p.price;
  var v=Math.floor(Math.random()*25)+5, rat=p.rating||4.8, rev=p.reviews||0;
  var dis=p.stock<=0?' disabled':'';

  var h='<div class="pd-img"><img src="'+(p.image||'https://placehold.co/400x400/1c2230/00d4aa?text=P')+'" onerror="this.src=\'https://placehold.co/400x400/1c2230/00d4aa?text=P\'"></div>';
  h+='<div class="pd-info"><h3>'+p.name+'</h3>';
  h+='<div class="pd-price">Rp '+fmt(fp)+'</div>';
  if(p.discount>0) h+='<div class="pd-old">Rp '+fmt(p.price)+'</div>';
  h+='<div class="pd-rating">★ '+rat+' ('+rev+' ulasan) | '+(p.sold||0)+'+ terjual</div>';
  h+='<div class="pd-viewers">'+v+' orang melihat produk ini</div>';
  h+='<div class="pd-desc">'+(p.description||'-')+'</div>';
  h+='<div class="pd-stock">'+(p.stock>0?'Stok: '+p.stock+' unit':'Stok habis')+'</div>';
  if(p.stock<=5&&p.stock>0) h+='<div class="pd-low">⚠ Hampir habis! Sisa '+p.stock+' unit</div>';
  h+='<button class="pd-btn primary" onclick="addCart(\''+p.id+'\')"'+dis+'>+ Tambah ke Keranjang</button>';
  h+='<button class="pd-btn secondary" onclick="buyNow(\''+p.id+'\')"'+dis+'>Beli Sekarang</button>';
  h+='</div>';

  document.getElementById('pdContent').innerHTML=h;
  document.getElementById('ovPD').classList.add('on');
}

// ═══════════════════════════════════════════
// RECENTLY VIEWED
// ═══════════════════════════════════════════
function addRecent(id) {
  recent=recent.filter(function(r){return r!==id;});
  recent.unshift(id);
  if(recent.length>10) recent=recent.slice(0,10);
  localStorage.setItem('neo_recent',JSON.stringify(recent));
  renderRecent();
}

function renderRecent() {
  if(!recent.length||!products.length){document.getElementById('recentWrap').style.display='none';return;}
  var items=[];
  for(var i=0;i<recent.length;i++){var p=find(recent[i]);if(p)items.push(p);}
  if(!items.length){document.getElementById('recentWrap').style.display='none';return;}
  document.getElementById('recentWrap').style.display='';
  var h='';
  for(var j=0;j<items.length;j++){
    var p=items[j],pr=p.discount>0?Math.round(p.price*(1-p.discount/100)):p.price;
    h+='<div class="rc" onclick="showPD(\''+p.id+'\')"><img src="'+p.image+'" onerror="this.src=\'https://placehold.co/110x110/1c2230/00d4aa?text=P\'"><div class="rc-name">'+p.name+'</div><div class="rc-price">Rp '+fmt(pr)+'</div></div>';
  }
  document.getElementById('recentRow').innerHTML=h;
}

// ═══════════════════════════════════════════
// CART
// ═══════════════════════════════════════════
function addCart(id) {
  var p=find(id);
  if(!p||p.stock<=0){toast('Stok habis!','err');return;}
  var ex=null;
  for(var i=0;i<cart.length;i++){if(cart[i].id===id){ex=cart[i];break;}}
  if(ex){if(ex.qty>=p.stock){toast('Stok tidak cukup!','err');return;}ex.qty++;}
  else{cart.push({id:p.id,name:p.name,price:p.discount>0?Math.round(p.price*(1-p.discount/100)):p.price,image:p.image||'',qty:1});}
  saveCart(); syncCartUI();
  toast('✓ Masuk keranjang!','ok');
  document.getElementById('ovPD').classList.remove('on');
}

function buyNow(id){addCart(id);setTimeout(openCart,300);}

function changeQty(id,d){
  for(var i=0;i<cart.length;i++){if(cart[i].id===id){cart[i].qty+=d;if(cart[i].qty<=0)cart.splice(i,1);break;}}
  saveCart();syncCartUI();
}

function delItem(id){cart=cart.filter(function(c){return c.id!==id;});saveCart();syncCartUI();}

function saveCart(){localStorage.setItem('neo_cart',JSON.stringify(cart));}

function syncCartUI() {
  var cnt=0,sub=0;
  for(var i=0;i<cart.length;i++){cnt+=cart[i].qty;sub+=cart[i].price*cart[i].qty;}
  var free=sub>=SHIP_MIN, ship=(free||!cart.length)?0:SHIP_COST;
  var disc=coupon?coupon.discount:0, total=Math.max(0,sub-disc+ship);

  var badge=document.getElementById('badgeCart');
  badge.textContent=cnt; badge.className='badge'+(cnt>0?' show':'');

  document.getElementById('sumSub').textContent='Rp '+fmt(sub);
  document.getElementById('sumShip').textContent=free?'GRATIS 🎉':'Rp '+fmt(ship);
  document.getElementById('sumShip').style.color=free?'var(--success)':'';
  document.getElementById('sumTotal').textContent='Rp '+fmt(total);
  document.getElementById('coTotal').textContent='Rp '+fmt(total);

  if(disc>0){document.getElementById('sumDiscRow').style.display='flex';document.getElementById('sumDisc').textContent='-Rp '+fmt(disc);}
  else{document.getElementById('sumDiscRow').style.display='none';}

  var pct=Math.min((sub/SHIP_MIN)*100,100);
  document.getElementById('shipFill').style.width=pct+'%';
  document.getElementById('shipMsg').innerHTML=free?'🎉 <b>GRATIS ONGKIR</b> berlaku!':'Belanja <b>Rp '+fmt(SHIP_MIN-sub)+'</b> lagi untuk GRATIS ONGKIR!';

  var el=document.getElementById('cartList');
  if(!cart.length){el.innerHTML='<div class="cart-empty">Keranjang masih kosong</div>';return;}
  var h='';
  for(var j=0;j<cart.length;j++){
    var c=cart[j];
    h+='<div class="ci"><img src="'+(c.image||'https://placehold.co/56x56/1c2230/00d4aa?text=P')+'" onerror="this.src=\'https://placehold.co/56x56/1c2230/00d4aa?text=P\'">';
    h+='<div class="ci-info"><div class="ci-name">'+c.name+'</div><div class="ci-price">Rp '+fmt(c.price*c.qty)+'</div>';
    h+='<div class="ci-actions"><button class="q-btn" onclick="changeQty(\''+c.id+'\',-1)">−</button><span class="qty">'+c.qty+'</span><button class="q-btn" onclick="changeQty(\''+c.id+'\',1)">+</button><button class="ci-del" onclick="delItem(\''+c.id+'\')">Hapus</button></div></div></div>';
  }
  el.innerHTML=h;
}

function openCart(){document.getElementById('cartBg').classList.add('on');document.getElementById('cartPanel').classList.add('on');}
function closeCart(){document.getElementById('cartBg').classList.remove('on');document.getElementById('cartPanel').classList.remove('on');}

// ═══════════════════════════════════════════
// COUPON
// ═══════════════════════════════════════════
function useCoupon() {
  var code=document.getElementById('inpCoupon').value.trim().toUpperCase();
  var note=document.getElementById('couponNote');
  if(!code){note.textContent='Masukkan kode';note.className='coupon-note no';return;}
  var sub=0;for(var i=0;i<cart.length;i++)sub+=cart[i].price*cart[i].qty;

  if(API){
    GET('validateCoupon','&code='+encodeURIComponent(code)+'&total='+sub).then(function(r){
      if(r&&r.success){coupon={code:code,discount:r.discount};note.textContent='✓ '+r.message;note.className='coupon-note ok';}
      else{note.textContent=(r&&r.error)||'Tidak valid';note.className='coupon-note no';coupon=null;}
      syncCartUI();
    });
  } else {
    if(code==='WELCOME10'){var d=Math.round(sub*0.1);coupon={code:code,discount:d};note.textContent='✓ Diskon 10% (-Rp '+fmt(d)+')';note.className='coupon-note ok';}
    else if(code==='HEMAT50K'&&sub>=200000){coupon={code:code,discount:50000};note.textContent='✓ Diskon Rp 50.000';note.className='coupon-note ok';}
    else{note.textContent='Kode tidak valid';note.className='coupon-note no';coupon=null;}
    syncCartUI();
  }
}

// ═══════════════════════════════════════════
// CHECKOUT
// ═══════════════════════════════════════════
function beginCheckout(){if(!cart.length){toast('Keranjang kosong!','err');return;}closeCart();setTimeout(function(){document.getElementById('ovCO').classList.add('on');},200);}
function closeCO(){document.getElementById('ovCO').classList.remove('on');}

function doOrder(e) {
  e.preventDefault();
  var sub=0;for(var i=0;i<cart.length;i++)sub+=cart[i].price*cart[i].qty;
  var free=sub>=SHIP_MIN,ship=free?0:SHIP_COST,disc=coupon?coupon.discount:0;
  var total=Math.max(0,sub-disc+ship);
  var cp=document.getElementById('coCoupon').value.trim()||(coupon?coupon.code:'');

  var items=[];for(var j=0;j<cart.length;j++){var c=cart[j];items.push({id:c.id,name:c.name,price:c.price,qty:c.qty});}

  var body={action:'createOrder',customer:document.getElementById('coName').value,phone:document.getElementById('coPhone').value,address:document.getElementById('coAddr').value,items:items,total:total,coupon:cp};

  var btn=e.target.querySelector('[type="submit"]');
  btn.disabled=true;btn.textContent='Memproses...';

  function done(oid){
    cart=[];coupon=null;saveCart();syncCartUI();closeCO();
    document.getElementById('frmCO').reset();
    document.getElementById('inpCoupon').value='';
    document.getElementById('couponNote').textContent='';
    btn.disabled=false;btn.textContent='Buat Pesanan';
    document.getElementById('okMsg').textContent='ID Pesanan: '+oid+'. Admin akan memproses dan mengirim notifikasi segera.';
    document.getElementById('ovOK').classList.add('on');
  }

  if(API){
    POST(body).then(function(r){
      if(r&&r.success){done(r.id);}
      else{toast((r&&r.error)||'Gagal','err');btn.disabled=false;btn.textContent='Buat Pesanan';}
    });
  } else {
    setTimeout(function(){done('ORD-'+Math.random().toString(36).substr(2,8).toUpperCase());},700);
  }
}

// ═══════════════════════════════════════════
// ADMIN
// ═══════════════════════════════════════════
function connectApi() {
  var url=document.getElementById('inpApi').value.trim();
  if(!url){toast('Masukkan URL','err');return;}
  API=url; localStorage.setItem('neo_api',url);
  var st=document.getElementById('apiStatus');
  st.textContent='Testing...';st.style.color='var(--text-muted)';

  GET('ping').then(function(r){
    if(r&&r.success){st.textContent='✓ Terhubung!';st.style.color='var(--success)';fetchProducts();fetchOrders();fetchStats();toast('Terhubung ke Google Sheets!','ok');}
    else{st.textContent='✗ Gagal';st.style.color='var(--error)';toast('Gagal. Cek URL dan pastikan sudah deploy.','err');}
  });
}

function doAddProduct(e) {
  e.preventDefault();
  var d={action:'addProduct',name:document.getElementById('pName').value,price:Number(document.getElementById('pPrice').value),category:document.getElementById('pCat').value,stock:Number(document.getElementById('pStock').value),description:document.getElementById('pDesc').value,image:document.getElementById('pImg').value,discount:Number(document.getElementById('pDisc').value)||0};

  if(API){
    POST(d).then(function(r){
      if(r&&r.success){toast('Produk diupload!','ok');fetchProducts();fetchStats();}
      else{toast((r&&r.error)||'Gagal','err');}
    });
  } else {
    products.push({id:'l'+Date.now(),name:d.name,price:d.price,category:d.category,stock:d.stock,description:d.description,image:d.image,discount:d.discount,sold:0,rating:5,reviews:0});
    renderProducts();renderFlash();toast('Ditambahkan (demo)','ok');
  }
  document.getElementById('frmProd').reset();
}

function fetchOrders() {
  if(!API) return;
  GET('getOrders').then(function(r){
    if(r&&r.success&&r.orders&&r.orders.length){
      var h='';var list=r.orders.slice(0,20);
      for(var i=0;i<list.length;i++){
        var o=list[i];
        h+='<tr><td style="font-family:monospace;font-size:0.72rem">'+(o.id||'')+'</td><td>'+(o.customer||'')+'</td><td style="font-family:var(--font-display);font-weight:600">Rp '+fmt(o.total||0)+'</td><td><span class="pill pill-'+(o.status||'pending')+'">'+(o.status||'pending')+'</span></td></tr>';
      }
      document.getElementById('tbOrders').innerHTML=h;
    }
  });
}

function fetchStats() {
  if(!API) return;
  GET('getStats').then(function(r){
    if(r&&r.success&&r.stats){
      document.getElementById('sRev').textContent='Rp '+fmt(r.stats.totalRevenue||0);
      document.getElementById('sOrd').textContent=r.stats.totalOrders||0;
      document.getElementById('sPen').textContent=r.stats.pendingOrders||0;
      document.getElementById('sProd').textContent=r.stats.totalProducts||0;
    }
  });
}

// ═══════════════════════════════════════════
// CONVERSION FEATURES
// ═══════════════════════════════════════════
function countdown() {
  function tick(){
    var now=new Date(),end=new Date(now);end.setHours(23,59,59,0);
    var d=end-now;if(d<=0)return;
    var h=Math.floor(d/36e5),m=Math.floor((d%36e5)/6e4),s=Math.floor((d%6e4)/1e3);
    document.getElementById('tH').textContent=pad(h);
    document.getElementById('tM').textContent=pad(m);
    document.getElementById('tS').textContent=pad(s);
  }
  tick();setInterval(tick,1000);
}

function socialLoop() {
  var msgs=['🔥 {n} orang belanja sekarang','✅ {c} baru membeli {p}','📦 {n} pesanan dikirim hari ini','⭐ {n} review bintang 5 minggu ini'];
  var cities=['Jakarta','Surabaya','Bandung','Medan','Semarang','Makassar','Yogyakarta','Bali','Malang','Bogor'];
  setInterval(function(){
    var i=Math.floor(Math.random()*msgs.length);
    var t=msgs[i].replace('{n}',Math.floor(Math.random()*120)+30).replace('{c}',cities[Math.floor(Math.random()*cities.length)]).replace('{p}',products.length?products[Math.floor(Math.random()*products.length)].name.substring(0,26):'Produk');
    document.getElementById('proofText').textContent=t;
  },4500);
}

// ═══════════════════════════════════════════
// NAV & UI
// ═══════════════════════════════════════════
function catNavBind() {
  var nav=document.getElementById('catNav');
  nav.addEventListener('click',function(e){
    var btn=e.target.closest('.cat-btn');if(!btn)return;
    setCat(btn.getAttribute('data-cat'));
  });
}

function setCat(c) {
  curCat=c;
  var btns=document.querySelectorAll('.cat-btn');
  for(var i=0;i<btns.length;i++){btns[i].classList.toggle('on',btns[i].getAttribute('data-cat')===c);}
  renderProducts();
  go('shop');
}

function go(v) {
  var views=document.querySelectorAll('.view');
  for(var i=0;i<views.length;i++) views[i].classList.remove('on');
  document.getElementById('v'+v.charAt(0).toUpperCase()+v.slice(1)).classList.add('on');
  document.querySelector('.cat-nav').style.display=v==='shop'?'flex':'none';
  if(v==='admin'){fetchOrders();fetchStats();}
}

function mnActive(b){var all=document.querySelectorAll('.mn-btn');for(var i=0;i<all.length;i++)all[i].classList.remove('on');b.classList.add('on');}
function wish(b){b.classList.toggle('liked');b.textContent=b.classList.contains('liked')?'♥':'♡';}

// ═══════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════
function find(id){for(var i=0;i<products.length;i++){if(products[i].id===id)return products[i];}return null;}
function fmt(n){return Number(n||0).toString().replace(/\B(?=(\d{3})+(?!\d))/g,'.');}
function pad(n){return n<10?'0'+n:''+n;}
function safeJSON(s,d){try{return JSON.parse(s)||d;}catch(e){return d;}}

function toast(msg,type){
  var t=document.getElementById('toast');
  t.textContent=msg;t.className='toast on '+(type||'');
  setTimeout(function(){t.classList.remove('on');},3000);
}
</script>
</body>
</html>
