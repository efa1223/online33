<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg-primary: #0f1219;
  --bg-secondary: #161b25;
  --bg-tertiary: #1c2230;
  --bg-card: #181e2a;
  --bg-hover: #222938;
  --accent: #00d4aa;
  --accent-dim: #00a885;
  --accent-glow: rgba(0, 212, 170, 0.25);
  --accent2: #a855f7;
  --accent2-dim: #7c3aed;
  --text-primary: #e8eaf0;
  --text-secondary: #9ca3b4;
  --text-muted: #5c6478;
  --border: #2a3140;
  --success: #22c55e;
  --warning: #eab308;
  --error: #ef4444;
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 20px;
  --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
  --font-display: 'Space Grotesk', system-ui, sans-serif;
  --font-body: 'Inter', system-ui, sans-serif;
}

html { font-size: 16px; scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  background: var(--bg-primary);
  color: var(--text-primary);
  line-height: 1.6;
  min-height: 100vh;
  min-height: 100dvh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 { font-family: var(--font-display); text-wrap: balance; line-height: 1.2; }
button { font-family: inherit; cursor: pointer; border: none; outline: none; }
button:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
input, textarea, select { font-family: inherit; font-size: 1rem; }
img { max-width: 100%; display: block; }
a { text-decoration: none; color: inherit; }

/* ═══════════ ANNOUNCEMENT BAR ═══════════ */
.announce {
  background: linear-gradient(90deg, #a855f7, #00d4aa);
  padding: 9px 16px;
  text-align: center;
  font-size: 0.78rem;
  font-weight: 600;
  color: #0f1219;
  overflow: hidden;
  white-space: nowrap;
}

.announce-inner {
  display: inline-block;
  animation: scroll-left 28s linear infinite;
}

@keyframes scroll-left {
  0% { transform: translateX(70vw); }
  100% { transform: translateX(-100%); }
}

/* ═══════════ HEADER ═══════════ */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(15, 18, 25, 0.92);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-bottom: 1px solid var(--border);
  padding: 10px 0;
}

.header-inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 20px;
  display: flex;
  align-items: center;
  gap: 14px;
}

.logo {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: -0.03em;
  flex-shrink: 0;
}

.logo b { color: var(--accent2); }

.search-wrap {
  flex: 1;
  max-width: 560px;
  position: relative;
}

.search-wrap input {
  width: 100%;
  padding: 9px 14px 9px 40px;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: 100px;
  color: var(--text-primary);
  font-size: 0.9rem;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.search-wrap input::placeholder { color: var(--text-muted); }
.search-wrap input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); outline: none; }

.search-wrap .ico {
  position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
  width: 18px; height: 18px; color: var(--text-muted); pointer-events: none;
}

.hdr-actions { display: flex; gap: 6px; flex-shrink: 0; }

.hdr-btn {
  position: relative;
  width: 40px; height: 40px;
  border-radius: 50%;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  color: var(--text-secondary);
  transition: all 0.2s var(--ease-out-expo);
}

.hdr-btn:hover { background: var(--bg-hover); color: var(--accent); border-color: var(--accent-dim); }

.hdr-btn .badge {
  position: absolute; top: -3px; right: -3px;
  min-width: 18px; height: 18px;
  background: var(--accent2);
  border-radius: 100px;
  font-size: 0.65rem; font-weight: 700;
  display: none; align-items: center; justify-content: center;
  color: #fff; padding: 0 4px;
}

.hdr-btn .badge.show { display: flex; }

/* ═══════════ NAV CATEGORIES ═══════════ */
.cat-nav {
  max-width: 1400px;
  margin: 0 auto;
  padding: 14px 20px 0;
  display: flex;
  gap: 7px;
  overflow-x: auto;
  scrollbar-width: none;
}

.cat-nav::-webkit-scrollbar { display: none; }

.cat-btn {
  padding: 7px 16px;
  border-radius: 100px;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  color: var(--text-secondary);
  font-size: 0.82rem;
  font-weight: 500;
  white-space: nowrap;
  transition: all 0.2s var(--ease-out-expo);
}

.cat-btn:hover { background: var(--bg-hover); color: var(--text-primary); }
.cat-btn.on { background: var(--accent); color: #0f1219; border-color: var(--accent); font-weight: 600; }

/* ═══════════ MAIN WRAP ═══════════ */
.main { max-width: 1400px; margin: 0 auto; padding: 20px; }
.view { display: none; }
.view.on { display: block; }

/* ═══════════ SOCIAL PROOF ═══════════ */
.social {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 16px;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  margin-bottom: 20px;
  font-size: 0.82rem;
  color: var(--text-secondary);
}

.social .dot {
  width: 7px; height: 7px;
  background: var(--success);
  border-radius: 50%;
  flex-shrink: 0;
  animation: blink 2s infinite;
}

@keyframes blink { 0%,100% { opacity:1; } 50% { opacity:0.4; } }

/* ═══════════ FLASH SALE ═══════════ */
.flash {
  background: linear-gradient(135deg, #1f1418, #1a1225);
  border: 1px solid #3d2020;
  border-radius: var(--radius-lg);
  padding: 20px;
  margin-bottom: 24px;
  position: relative;
  overflow: hidden;
}

.flash::after {
  content: '';
  position: absolute; top: -60%; right: -15%;
  width: 50%; height: 220%;
  background: radial-gradient(ellipse, rgba(239,68,68,0.08), transparent 70%);
  pointer-events: none;
}

.flash-top {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 14px; flex-wrap: wrap; gap: 10px;
  position: relative; z-index: 1;
}

.flash-top h2 { font-size: 1.1rem; color: #fff; }

.timer { display: flex; gap: 4px; align-items: center; }

.timer-box {
  background: #0f1219;
  padding: 5px 9px;
  border-radius: 6px;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.95rem;
  min-width: 36px;
  text-align: center;
  font-variant-numeric: tabular-nums;
}

.timer-sep { color: var(--error); font-weight: 700; font-size: 0.9rem; }

.flash-row {
  display: flex; gap: 10px;
  overflow-x: auto;
  padding-bottom: 6px;
  scrollbar-width: none;
  position: relative; z-index: 1;
}

.flash-row::-webkit-scrollbar { display: none; }

.fs-card {
  flex-shrink: 0; width: 145px;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1px solid var(--border);
  cursor: pointer;
  transition: all 0.2s var(--ease-out-expo);
}

.fs-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.3); }
.fs-card .thumb { aspect-ratio: 1; background: var(--bg-tertiary); overflow: hidden; }
.fs-card .thumb img { width: 100%; height: 100%; object-fit: cover; }
.fs-card .fs-body { padding: 8px; }
.fs-card .fs-price { font-family: var(--font-display); font-weight: 700; color: var(--error); font-size: 0.88rem; }
.fs-card .fs-old { font-size: 0.65rem; color: var(--text-muted); text-decoration: line-through; }
.fs-card .fs-bar { margin-top: 5px; height: 3px; background: var(--bg-tertiary); border-radius: 2px; overflow: hidden; }
.fs-card .fs-fill { height: 100%; background: linear-gradient(90deg, var(--error), var(--warning)); border-radius: 2px; }
.fs-card .fs-label { font-size: 0.6rem; color: var(--text-muted); margin-top: 3px; }

/* ═══════════ HERO BANNER ═══════════ */
.hero {
  border-radius: var(--radius-lg);
  padding: 44px 36px;
  background: linear-gradient(135deg, #141b2d, #1a1530);
  position: relative;
  overflow: hidden;
  margin-bottom: 28px;
}

.hero::before {
  content: '';
  position: absolute; top: -50%; right: -20%;
  width: 60%; height: 200%;
  background: radial-gradient(ellipse, var(--accent-glow), transparent 70%);
  pointer-events: none;
}

.hero h1 { font-size: clamp(1.4rem, 4vw, 2.4rem); margin-bottom: 8px; position: relative; }
.hero p { color: var(--text-secondary); font-size: 0.95rem; max-width: 48ch; position: relative; }

/* ═══════════ TRUST ROW ═══════════ */
.trust {
  display: flex; gap: 14px; justify-content: center;
  padding: 14px; margin-bottom: 22px; flex-wrap: wrap;
}

.trust-item {
  display: flex; align-items: center; gap: 5px;
  font-size: 0.72rem; color: var(--text-muted); font-weight: 500;
}

.trust-item svg { width: 15px; height: 15px; color: var(--accent); flex-shrink: 0; }

/* ═══════════ RECENTLY VIEWED ═══════════ */
.recent { margin-bottom: 28px; }

.recent-row {
  display: flex; gap: 10px;
  overflow-x: auto; padding-bottom: 6px;
  scrollbar-width: none;
}

.recent-row::-webkit-scrollbar { display: none; }

.rc { flex-shrink: 0; width: 110px; cursor: pointer; transition: transform 0.2s; }
.rc:hover { transform: scale(1.04); }
.rc img { width: 110px; height: 110px; border-radius: var(--radius-sm); object-fit: cover; background: var(--bg-tertiary); }
.rc .rc-name { font-size: 0.68rem; color: var(--text-secondary); margin-top: 5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.rc .rc-price { font-size: 0.76rem; font-weight: 600; color: var(--accent); font-family: var(--font-display); }

/* ═══════════ SECTION TITLE ═══════════ */
.sec-title { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
.sec-title h2 { font-size: 1.15rem; }

/* ═══════════ PRODUCT GRID ═══════════ */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(185px, 1fr));
  gap: 14px;
  margin-bottom: 40px;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  overflow: hidden;
  transition: all 0.3s var(--ease-out-expo);
  cursor: pointer;
  position: relative;
}

.card:hover {
  transform: translateY(-4px);
  border-color: var(--accent-dim);
  box-shadow: 0 10px 36px rgba(0,0,0,0.35), 0 0 16px var(--accent-glow);
}

.card .pic { aspect-ratio: 1; background: var(--bg-tertiary); overflow: hidden; position: relative; }
.card .pic img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s var(--ease-out-expo); }
.card:hover .pic img { transform: scale(1.06); }

.card .tag-disc {
  position: absolute; top: 7px; left: 7px;
  background: var(--error); color: #fff;
  font-size: 0.67rem; font-weight: 700;
  padding: 2px 7px; border-radius: 4px;
}

.card .tag-sold {
  position: absolute; bottom: 7px; right: 7px;
  background: rgba(15,18,25,0.8);
  backdrop-filter: blur(6px);
  color: var(--text-secondary);
  font-size: 0.62rem; font-weight: 500;
  padding: 2px 7px; border-radius: 4px;
}

.card .btn-wish {
  position: absolute; top: 7px; right: 7px;
  width: 28px; height: 28px;
  border-radius: 50%;
  background: rgba(15,18,25,0.7);
  backdrop-filter: blur(6px);
  display: flex; align-items: center; justify-content: center;
  color: var(--text-muted); font-size: 0.85rem;
  border: none; cursor: pointer; transition: all 0.15s;
}

.card .btn-wish:hover, .card .btn-wish.liked { color: var(--error); }

.card .body { padding: 10px; }

.card .title {
  font-size: 0.82rem; color: var(--text-primary);
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden; line-height: 1.4; margin-bottom: 6px;
}

.card .price-row {
  font-family: var(--font-display);
  font-size: 1rem; font-weight: 700; color: var(--accent);
}

.card .price-row .old {
  font-size: 0.72rem; color: var(--text-muted);
  text-decoration: line-through; margin-left: 5px; font-weight: 400;
}

.card .meta-row {
  display: flex; align-items: center; gap: 7px;
  margin-top: 5px; font-size: 0.72rem; color: var(--text-muted);
}

.card .meta-row .star { color: var(--warning); }

.card .low-stock {
  display: flex; align-items: center; gap: 4px;
  font-size: 0.68rem; color: var(--error); font-weight: 500; margin-top: 4px;
}

.card .low-stock::before {
  content: ''; width: 5px; height: 5px;
  background: var(--error); border-radius: 50%;
  animation: blink 1.5s infinite;
}

.card .hover-btns {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 9px;
  background: linear-gradient(0deg, rgba(15,18,25,0.96) 60%, transparent);
  transform: translateY(100%);
  transition: transform 0.3s var(--ease-out-expo);
  display: flex; gap: 6px;
}

.card:hover .hover-btns { transform: translateY(0); }

.hover-btns button {
  flex: 1; padding: 7px;
  border-radius: 6px; font-size: 0.72rem; font-weight: 600;
  transition: opacity 0.15s;
}

.hover-btns button:hover { opacity: 0.85; }
.hover-btns .hb-cart { background: var(--accent); color: #0f1219; }
.hover-btns .hb-buy { background: var(--accent2); color: #fff; }

/* ═══════════ CART PANEL ═══════════ */
.cart-bg {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.55);
  z-index: 200;
  opacity: 0; visibility: hidden;
  transition: all 0.3s var(--ease-out-expo);
}

.cart-bg.on { opacity: 1; visibility: visible; }

.cart-panel {
  position: fixed; top: 0; right: 0; bottom: 0;
  width: 390px; max-width: 92vw;
  background: var(--bg-secondary);
  border-left: 1px solid var(--border);
  z-index: 201;
  transform: translateX(100%);
  transition: transform 0.4s var(--ease-out-expo);
  display: flex; flex-direction: column;
}

.cart-panel.on { transform: translateX(0); }

.cart-top {
  padding: 18px 20px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
}

.cart-top h3 { font-size: 1.05rem; }

.cart-x {
  width: 34px; height: 34px;
  border-radius: 50%;
  background: var(--bg-tertiary);
  display: flex; align-items: center; justify-content: center;
  color: var(--text-secondary); transition: all 0.15s;
}

.cart-x:hover { background: var(--error); color: #fff; }

/* Free Shipping */
.ship-bar {
  padding: 10px 20px;
  font-size: 0.78rem; color: var(--text-secondary);
  border-bottom: 1px solid var(--border);
}

.ship-track { height: 4px; background: var(--bg-tertiary); border-radius: 2px; margin-top: 6px; overflow: hidden; }
.ship-fill { height: 100%; background: linear-gradient(90deg, var(--accent), var(--success)); border-radius: 2px; transition: width 0.4s var(--ease-out-expo); width: 0%; }

/* Cart Items */
.cart-list { flex: 1; overflow-y: auto; padding: 14px 20px; }

.ci {
  display: flex; gap: 10px;
  padding: 11px 0;
  border-bottom: 1px solid var(--border);
  animation: fadeX 0.3s var(--ease-out-expo);
}

@keyframes fadeX { from { opacity:0; transform:translateX(8px); } to { opacity:1; transform:translateX(0); } }

.ci img { width: 56px; height: 56px; border-radius: var(--radius-sm); object-fit: cover; background: var(--bg-tertiary); flex-shrink: 0; }
.ci-info { flex: 1; min-width: 0; }
.ci-name { font-size: 0.82rem; margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ci-price { font-size: 0.88rem; font-weight: 600; color: var(--accent); }

.ci-actions { display: flex; align-items: center; gap: 6px; margin-top: 5px; }

.q-btn {
  width: 24px; height: 24px;
  border-radius: 5px;
  background: var(--bg-tertiary);
  border: 1px solid var(--border);
  color: var(--text-secondary);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.85rem; transition: all 0.15s;
}

.q-btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }

.ci-actions .qty { font-size: 0.82rem; font-weight: 500; min-width: 18px; text-align: center; }

.ci-del {
  margin-left: auto;
  background: none; color: var(--text-muted);
  font-size: 0.72rem; padding: 3px 6px;
  border-radius: 4px; transition: all 0.15s;
}

.ci-del:hover { color: var(--error); background: rgba(239,68,68,0.1); }

.cart-empty { text-align: center; padding: 44px 20px; color: var(--text-muted); font-size: 0.9rem; }

/* Coupon */
.coupon-area { padding: 10px 20px; border-top: 1px solid var(--border); }
.coupon-flex { display: flex; gap: 6px; }

.coupon-flex input {
  flex: 1; padding: 7px 10px;
  background: var(--bg-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-primary);
  font-size: 0.82rem;
  text-transform: uppercase;
}

.coupon-flex input:focus { border-color: var(--accent); outline: none; }

.coupon-flex button {
  padding: 7px 12px;
  background: var(--bg-tertiary);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-secondary);
  font-size: 0.78rem; font-weight: 600;
  transition: all 0.15s;
}

.coupon-flex button:hover { background: var(--accent); color: #fff; border-color: var(--accent); }

.coupon-note { font-size: 0.72rem; margin-top: 5px; }
.coupon-note.ok { color: var(--success); }
.coupon-note.no { color: var(--error); }

/* Cart Footer */
.cart-foot {
  padding: 18px 20px;
  border-top: 1px solid var(--border);
  background: var(--bg-primary);
}

.summary-row { display: flex; justify-content: space-between; font-size: 0.82rem; color: var(--text-secondary); padding: 3px 0; }
.summary-row.big { font-size: 1.05rem; font-weight: 700; color: var(--text-primary); padding-top: 8px; border-top: 1px solid var(--border); margin-top: 6px; }
.summary-row.big .val { color: var(--accent); font-family: var(--font-display); }
.summary-row .green { color: var(--success); }

.btn-co {
  display: block; width: 100%; margin-top: 14px;
  padding: 13px;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, var(--accent), var(--accent2));
